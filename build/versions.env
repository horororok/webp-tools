# 재현 가능한 WASM 빌드를 위한 핀 박은 버전.
# 의도적으로 올릴 것; 올릴 땐 재빌드 후 semver 올려서 재배포.

# Emscripten SDK Docker 이미지 태그 (https://hub.docker.com/r/emscripten/emsdk/tags).
# 검증된 안정 태그; 새 태그로 자유롭게 올려도 됨(libwebp는 최근 emsdk면 빌드됨).
EMSDK_VERSION=3.1.74

# libwebp 최신 stable (2026-05 확인): 1.6.0 (2025-06-30 릴리스).
LIBWEBP_VERSION=1.6.0

# giflib stable (sourceforge): gif2webp가 GIF 디코딩에 링크.
GIFLIB_VERSION=5.2.2
